# NAZCA EEW API — copiar a .env y ajustar valores
APP_NAME=NAZCA EEW API
DEBUG=false
API_MASTER_KEY=change-me-to-a-secure-random-key

# PostgreSQL + PostGIS (TLS en producción)
DATABASE_URL=postgresql+asyncpg://eew:eew_secret@localhost:5432/eew_db
DATABASE_SSL=false

# Redis (cola de alertas EEW)
REDIS_URL=redis://localhost:6379/0
REDIS_SSL=false
EEW_QUEUE_NAME=eew:alerts

# Fuentes Open Data (opcional)
FIRMS_API_KEY=
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
